<Window x:Class="VietnamFoodGuide.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vietnam Food Guide"
        Height="750" Width="1100"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="BtnBorder" Background="White" BorderBrush="#E0E0E0" 
                                BorderThickness="1" CornerRadius="20" Padding="18,8" Margin="5,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E63946"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#E63946"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="GroupName" Value="Categories"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Background="#F4F6F8">

            <Border Height="200" ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/Images/banner.png" Stretch="UniformToFill"/>
                    <Border Background="#60000000"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Vietnam Food Guide" Foreground="White" FontSize="50" FontWeight="ExtraBold" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.7" ShadowDepth="3"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Khám phá ẩm thực tinh túy Việt Nam" Foreground="White" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.9"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="25" Height="50" MaxWidth="600" Margin="0,-25,0,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="5" Direction="270"/>
                </Border.Effect>
                <Grid Margin="20,0,20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Text="🔍" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Bạn muốn ăn gì hôm nay?" Foreground="#A0A0A0" FontSize="16" FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" FontSize="16" VerticalContentAlignment="Center" TextChanged="SearchFood" Padding="30,0,0,0" Panel.ZIndex="1"/>
                </Grid>
            </Border>

            <ScrollViewer x:Name="CategoryScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="140,0,20,15" PreviewMouseWheel="CategoryScroll_PreviewMouseWheel">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <RadioButton Content="Tất cả" IsChecked="True" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="🍜 Phở" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="🍲 Bún" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="🍚 Cơm" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="🥖 Bánh Mì" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="🥮 Bánh Khác" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                    <RadioButton Content="☕ Thức uống" Style="{StaticResource CategoryButtonStyle}" Click="FilterCategory"/>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <ScrollViewer Padding="20" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="FoodList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Margin="15" Background="White" CornerRadius="20" Padding="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="5"/>
                            </Border.Effect>
                            <StackPanel>
                                <Border CornerRadius="15" ClipToBounds="True">
                                    <Image Source="{Binding Image}" Height="180" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Margin="0,12,0,4" Foreground="#1D3557"/>
                                <Grid>
                                    <TextBlock Text="{Binding City}" Foreground="#457B9D" FontSize="14"/>
                                    <TextBlock Text="{Binding Rating, StringFormat=⭐ \{0:F1\}}" Foreground="#F4A261" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Button Content="Xem chi tiết" 
                                        Style="{StaticResource RoundedButtonStyle}" 
                                        Click="OpenDetail" 
                                        Margin="0,15,0,0" Height="40" 
                                        Background="#E63946" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>